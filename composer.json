{
    "name": "nazaryuzhyn/laravel-comments",
    "description": "Comments to Laravel application",
    "keywords": [
        "laravel",
        "comments",
        "laravel-comments"
    ],
    "homepage": "https://github.com/nazaryuzhyn/laravel-comments",
    "type": "library",
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "nazaryuzhyn",
            "email": "nazaryuzhyn@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Comments\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Comments\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Comments\\CommentsServiceProvider"
            ]
        }
    }
}
